# WanderAI Backend Configuration

# Server
PORT=5000

# Groq AI API
GROQ_API_KEY=your_groq_api_key_here

# Optional: Real API Integrations (replace with actual credentials)
# Skyscanner API
SKYSCANNER_API_KEY=your_skyscanner_key

# Hotels.com API
HOTELS_COM_API_KEY=your_hotels_com_key

# Payment Gateway (Stripe)
STRIPE_SECRET_KEY=your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key

# Email Service (SendGrid for booking confirmations)
SENDGRID_API_KEY=your_sendgrid_key

# Redis Cache (for production)
REDIS_URL=redis://localhost:6379

# Database
DATABASE_URL=mongodb://localhost:27017/wanderai

# Node Environment
NODE_ENV=development
